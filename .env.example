# Paytm Money API (https://developer.paytmmoney.com)
PAYTM_API_KEY=your_api_key_here
PAYTM_API_SECRET=your_api_secret_here

# Zerodha Kite Connect (https://developers.kite.trade)
ZERODHA_API_KEY=your_kite_api_key
ZERODHA_API_SECRET=your_kite_api_secret

# Notifications via Slack incoming webhook (Slack → Apps → Incoming Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXXXXXX

# Flask webhook server
WEBHOOK_PORT=5001
WEBHOOK_ENCRYPTION_KEY=generate_with__python3_-c__"from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Dashboard access — HTTP Basic Auth guarding /dashboard_main, /dashboard_bkp, /fire-*
# Pick a strong password: python3 -c "import secrets; print(secrets.token_urlsafe(18))"
DASHBOARD_USER=your_dashboard_username
DASHBOARD_PASS=your_strong_dashboard_password

# Cloudflare tunnel + Workers relay
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id
WORKERS_RELAY_URL=https://your-worker.your-subdomain.workers.dev
